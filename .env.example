# ╔══════════════════════════════════════════════════════════════╗
# ║  NuvuSalon Voice Agent — Environment Variables             ║
# ║  Copy to .env and fill in your values.                     ║
# ║  NEVER commit .env to version control.                     ║
# ╚══════════════════════════════════════════════════════════════╝

# ── General ───────────────────────────────────────────────────
APP_NAME=NuvuSalon Voice Agent
DEBUG=false
# Your Railway public URL (set after first deploy)
BASE_URL=https://your-app.up.railway.app
TMP_DIR=.tmp

# ── Twilio VoIP ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Your Twilio phone number in E.164 format
TWILIO_PHONE_NUMBER=+11234567890

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-2.0-flash

# ── Google Service Account ────────────────────────────────────
# Option A: Paste the ENTIRE service account JSON as a single line
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option B: Path to the JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# ── Google Sheets ─────────────────────────────────────────────
# Spreadsheet ID from the URL: docs.google.com/spreadsheets/d/<THIS_PART>/
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# ── Google Calendar ───────────────────────────────────────────
# "primary" or a specific calendar ID
GOOGLE_CALENDAR_ID=primary
APPOINTMENT_DURATION_MINUTES=60
SALON_TIMEZONE=America/New_York

# ── Email (SendGrid) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# Must be a verified sender in SendGrid
FROM_EMAIL=bookings@yoursalon.com
# Where the salon receives booking alerts
SALON_NOTIFICATION_EMAIL=owner@yoursalon.com

# ── Salon Info ────────────────────────────────────────────────
SALON_NAME=Nuvu Salon & Spa
KNOWLEDGE_BASE_PATH=knowledge_base/salon_info.json

# ── Scheduler ─────────────────────────────────────────────────
REMINDER_HOURS_BEFORE=24

# ── Voice Settings ────────────────────────────────────────────
# Twilio TTS voice: Polly.Joanna, Polly.Matthew, Polly.Salli, etc.
TTS_VOICE=Polly.Joanna
LANGUAGE=en-US
